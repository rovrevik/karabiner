{
  "description": "14-caps-word: ZMK-style caps word",
  "manipulators": [
    {
      "description": "caps_lock + left_option held, caps_word on → turn off",
      "type": "basic",
      "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
      "conditions": [
        { "type": "variable_if", "name": "physical_left_option", "value": 1 },
        { "type": "variable_if", "name": "caps_word", "value": 1 }
      ],
      "to": [{ "set_variable": { "name": "caps_word", "value": 0 } }]
    },
    {
      "description": "caps_lock + left_option held → caps_word on",
      "type": "basic",
      "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
      "conditions": [
        { "type": "variable_if", "name": "physical_left_option", "value": 1 }
      ],
      "to": [{ "set_variable": { "name": "caps_word", "value": 1 } }]
    },
    {
      "description": "caps_lock tap (left_option not held) → escape",
      "type": "basic",
      "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
      "conditions": [
        { "type": "variable_if", "name": "physical_left_option", "value": 0 }
      ],
      "to": [{ "key_code": "escape" }]
    },
    {
      "type": "basic",
      "from": { "key_code": "a" },
      "to": [{ "key_code": "a", "modifiers": ["left_shift"] }],
      "conditions": [{ "type": "variable_if", "name": "caps_word", "value": 1 }]
    },
