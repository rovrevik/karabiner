{
  "description": "12-thumbs",
  "manipulators": [
    {
      "description": "left_control → escape",
      "from": {
        "key_code": "left_control",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "escape"
        }
      ],
      "type": "basic"
    },
    {
      "description": "track physical {left_option} key",
      "from": {
        "key_code": "left_option",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "physical_left_option",
            "value": 1
          }
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "physical_left_option",
            "value": 0
          }
        }
      ],
      "to_if_alone": [
        {
          "key_code": "delete_or_backspace"
        }
      ],
      "type": "basic"
    },
    {
      "description": "track physical {left_command} key",
      "from": {
        "key_code": "left_command",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "physical_left_command",
            "value": 1
          }
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "physical_left_command",
            "value": 0
          }
        }
      ],
      "to_if_alone": [
        {
          "key_code": "tab"
        }
      ],
      "type": "basic"
    },
    {
      "description": "space → space",
      "from": {
        "key_code": "spacebar",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "spacebar"
        }
      ],
      "type": "basic"
    },
    {
      "description": "track physical right_command key",
      "from": {
        "key_code": "right_command",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "physical_right_command",
            "value": 1
          }
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "physical_right_command",
            "value": 0
          }
        }
      ],
      "to_if_alone": [
        {
          "key_code": "return_or_enter"
        }
      ],
      "type": "basic"
    }
  ]
}
