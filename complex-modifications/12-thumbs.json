{
  "description": "12-thumbs",
  "manipulators": [
    {
      "description": "left_control → escape",
      "from": {
        "key_code": "left_control",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "escape"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option quick-tap: double-tap-and-hold → repeat backspace",
      "conditions": [
        {
          "type": "variable_if",
          "name": "left_option_quick_tap",
          "value": 1
        }
      ],
      "from": {
        "key_code": "left_option",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "delete_or_backspace"
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "left_option_quick_tap",
            "value": 0
          }
        }
      ],
      "type": "basic"
    },
    {
      "description": "track physical {left_option} key",
      "from": {
        "key_code": "left_option",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "physical_left_option",
            "value": 1
          }
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "physical_left_option",
            "value": 0
          }
        }
      ],
      "to_if_alone": [
        {
          "key_code": "delete_or_backspace"
        },
        {
          "set_variable": {
            "name": "left_option_quick_tap",
            "value": 1
          }
        }
      ],
      "to_delayed_action": {
        "to_if_invoked": [
          {
            "set_variable": {
              "name": "left_option_quick_tap",
              "value": 0
            }
          }
        ],
        "to_if_canceled": [
          {
            "set_variable": {
              "name": "left_option_quick_tap",
              "value": 0
            }
          }
        ]
      },
      "parameters": {
        "basic.to_delayed_action_delay_milliseconds": 390
      },
      "type": "basic"
    },
