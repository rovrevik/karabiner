{
  "description": "05-numpad: physical left_command + keys for numpad layer",
  "manipulators": [
    {
      "description": "track physical left_command key",
      "from": {
        "key_code": "left_command",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "physical_left_command",
            "value": 1
          }
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "physical_left_command",
            "value": 0
          }
        }
      ],
      "to_if_alone": [
        {
          "key_code": "tab"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_command + q → `",
