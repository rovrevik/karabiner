{
  "description": "04-cursor: physical left_option + right hand navigation",
  "manipulators": [
    {
      "description": "track physical left_option key",
      "from": {
        "key_code": "left_option",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "set_variable": {
            "name": "physical_left_option",
            "value": 1
          }
        }
      ],
      "to_after_key_up": [
        {
          "set_variable": {
            "name": "physical_left_option",
            "value": 0
          }
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + j → left_arrow",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "j",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "left_arrow"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + k → down_arrow",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "k",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "down_arrow"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + l → up_arrow",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "l",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "up_arrow"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + semicolon → right_arrow",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "semicolon",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "right_arrow"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + m → home",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "m",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "home"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + comma → page_down",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "comma",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "page_down"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + period → page_up",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "period",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "page_up"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_option + slash → end",
      "conditions": [
        {
          "type": "variable_if",
          "name": "physical_left_option",
          "value": 1
        }
      ],
      "from": {
        "key_code": "slash",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "end"
        }
      ],
      "type": "basic"
    },
    {
      "description": "up_arrow → disabled",
      "from": {
        "key_code": "up_arrow",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "vk_none"
        }
      ],
      "type": "basic"
    },
    {
      "description": "down_arrow → disabled",
      "from": {
        "key_code": "down_arrow",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "vk_none"
        }
      ],
      "type": "basic"
    },
    {
      "description": "left_arrow → disabled",
      "from": {
        "key_code": "left_arrow",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "vk_none"
        }
      ],
      "type": "basic"
    },
    {
      "description": "right_arrow → disabled",
      "from": {
        "key_code": "right_arrow",
        "modifiers": {
          "optional": ["any"]
        }
      },
      "to": [
        {
          "key_code": "vk_none"
        }
      ],
      "type": "basic"
    }
  ]
}
